*.jks
*.p12
*.key
*.mobileprovision
*.cer
*.certSigningRequest

# Build outputs
*.ipa
*.aab
*.apk
*.tgz

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo

# Testing
coverage/

# Temporary files
*.tmp
*.temp
.cache/
